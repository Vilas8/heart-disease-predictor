# Copy this file to .env and fill in your values for local development.
# On Render or Vercel, add these as Environment Variables in the dashboard.
# NEVER commit your real .env file — it's in .gitignore.

# ── SMTP / Email Settings ──────────────────────────────────────────────────
# Gmail example (use an App Password, NOT your real Gmail password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ── For Outlook / Office 365 ───────────────────────────────────────────────
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password

# ── For custom SMTP (e.g. SendGrid, Mailgun) ──────────────────────────────
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
